# ─── BrahmaAI Backend Configuration ───────────────────────────────────────────
# Copy this to .env and fill in your values

# App
APP_NAME=BrahmaAI
DEBUG=false
SECRET_KEY=change-this-secret-key-in-production

# LLM Provider — choose one: openai | anthropic
LLM_PROVIDER=openai

# OpenAI (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# LLM Settings
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# Agent Loop
MAX_ITERATIONS=10
MAX_RETRIES=3
STEP_TIMEOUT_SECONDS=60

# Memory / Vector Store
FAISS_INDEX_PATH=./data/faiss_index
EMBEDDING_MODEL=text-embedding-3-small
SHORT_TERM_MAX_MESSAGES=50
LONG_TERM_TOP_K=5

# Tools
# Get a free key at https://serpapi.com (optional — falls back to DuckDuckGo)
SERPAPI_KEY=
SANDBOX_TIMEOUT_SECONDS=10

# Auth (change these in production!)
JWT_SECRET=change-this-jwt-secret
JWT_EXPIRE_MINUTES=1440

# CORS
ALLOWED_ORIGINS=["http://localhost:3000"]
